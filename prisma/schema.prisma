generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  name           String?
  email          String          @unique
  emailVerified  Boolean         @default(false)
  image          String?
  role           UserRole        @default(CUSTOMER)
  avatarUrl      String?         @map("avatar_url")
  phone          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  accounts       Account[]
  addresses      Address[]
  complaints     Complaint[]
  pickupRequests PickupRequest[] @relation("CustomerPickups")
  sessions       Session[]
  staff          Staff?

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Staff {
  id               String          @id @default(uuid())
  userId           String          @unique @map("user_id")
  outletId         String?         @map("outlet_id")
  role             StaffRole
  workerType       StationType?
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  adminBypasses    BypassRequest[] @relation("AdminBypasses")
  workerBypasses   BypassRequest[] @relation("WorkerBypasses")
  driverDeliveries Delivery[]
  createdOrders    Order[]         @relation("AdminOrders")
  driverPickups    PickupRequest[]
  shifts           Shift[]
  outlet           Outlet?         @relation(fields: [outletId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stationRecords   StationRecord[]

  @@index([outletId])
  @@map("staff")
}

model Outlet {
  id                 String          @id @default(uuid())
  name               String
  address            String
  city               String
  province           String
  latitude           Float
  longitude          Float
  maxServiceRadiusKm Float           @default(10.0) @map("max_service_radius_km")
  isActive           Boolean         @default(true) @map("is_active")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  orders             Order[]
  pickupRequests     PickupRequest[]
  shifts             Shift[]
  staff              Staff[]

  @@map("outlets")
}

model Address {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  label          String
  street         String
  city           String
  province       String
  latitude       Float
  longitude      Float
  isPrimary      Boolean         @default(false) @map("is_primary")
  createdAt      DateTime        @default(now()) @map("created_at")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickupRequests PickupRequest[]

  @@index([userId])
  @@map("addresses")
}

model Shift {
  id        String   @id @default(uuid())
  outletId  String   @map("outlet_id")
  startTime DateTime @map("start_time")
  endTime   DateTime? @map("end_time")
  staffId   String   @map("staff_id")
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  staff     Staff    @relation(fields: [staffId], references: [id])

  @@index([outletId])
  @@index([staffId])
  @@index([staffId, endTime])
  @@map("shifts")
}

model PickupRequest {
  id           String       @id @default(uuid())
  customerId   String       @map("customer_id")
  addressId    String       @map("address_id")
  outletId     String       @map("outlet_id")
  driverId     String?      @map("driver_id")
  scheduledAt  DateTime     @map("scheduled_at")
  status       PickupStatus @default(PENDING)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  order        Order?
  address      Address      @relation(fields: [addressId], references: [id])
  customerUser User         @relation("CustomerPickups", fields: [customerId], references: [id])
  driverStaff  Staff?       @relation(fields: [driverId], references: [id])
  outlet       Outlet       @relation(fields: [outletId], references: [id])

  @@index([customerId])
  @@index([outletId])
  @@index([driverId])
  @@map("pickup_requests")
}

model Order {
  id              String             @id @default(uuid())
  pickupRequestId String             @unique @map("pickup_request_id")
  outletId        String             @map("outlet_id")
  totalWeightKg   Float              @map("total_weight_kg")
  pricePerKg      Float              @map("price_per_kg")
  totalPrice      Float              @map("total_price")
  paymentStatus   OrderPaymentStatus @default(UNPAID) @map("payment_status")
  status          OrderStatus        @default(LAUNDRY_ARRIVED_AT_OUTLET)
  confirmedAt     DateTime?          @map("confirmed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  staffId         String             @map("staff_id")
  complaints      Complaint[]
  delivery        Delivery?
  items           OrderItem[]
  outlet          Outlet             @relation(fields: [outletId], references: [id])
  pickupRequest   PickupRequest      @relation(fields: [pickupRequestId], references: [id])
  admin           Staff              @relation("AdminOrders", fields: [staffId], references: [id])
  payment         Payment?
  stationRecords  StationRecord[]

  @@index([outletId])
  @@index([staffId])
  @@index([status, updatedAt])
  @@map("orders")
}

model LaundryItem {
  id           String        @id @default(uuid())
  name         String        @unique
  slug         String        @unique
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  orderItems   OrderItem[]
  stationItems StationItem[]

  @@map("laundry_items")
}

model OrderItem {
  id              String      @id @default(uuid())
  orderId         String      @map("order_id")
  quantity        Int
  unitPrice       Float?      @map("unit_price")
  lineTotal       Float?      @map("line_total")
  isManualPriced  Boolean     @default(false) @map("is_manual_priced")
  laundryItemId   String      @map("laundry_item_id")
  laundryItem     LaundryItem @relation(fields: [laundryItemId], references: [id])
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model StationRecord {
  id             String          @id @default(uuid())
  orderId        String          @map("order_id")
  station        StationType
  status         StationStatus   @default(IN_PROGRESS)
  completedAt    DateTime?       @map("completed_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  staffId        String          @map("staff_id")
  bypassRequests BypassRequest[]
  stationItems   StationItem[]
  order          Order           @relation(fields: [orderId], references: [id])
  staff          Staff           @relation(fields: [staffId], references: [id])

  @@unique([orderId, station])
  @@index([staffId])
  @@map("station_records")
}

model StationItem {
  id              String        @id @default(uuid())
  stationRecordId String        @map("station_record_id")
  quantity        Int
  laundryItemId   String        @map("laundry_item_id")
  laundryItem     LaundryItem   @relation(fields: [laundryItemId], references: [id])
  stationRecord   StationRecord @relation(fields: [stationRecordId], references: [id], onDelete: Cascade)

  @@index([stationRecordId])
  @@map("station_items")
}

model BypassRequest {
  id                 String        @id @default(uuid())
  stationRecordId    String        @map("station_record_id")
  workerId           String        @map("worker_id")
  adminId            String?       @map("admin_id")
  problemDescription String?       @map("problem_description")
  status             BypassStatus  @default(PENDING)
  resolvedAt         DateTime?     @map("resolved_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  admin              Staff?        @relation("AdminBypasses", fields: [adminId], references: [id])
  stationRecord      StationRecord @relation(fields: [stationRecordId], references: [id])
  worker             Staff         @relation("WorkerBypasses", fields: [workerId], references: [id])

  @@index([stationRecordId])
  @@index([workerId])
  @@index([adminId])
  @@map("bypass_requests")
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique @map("order_id")
  amount      Float
  gateway     String
  gatewayTxId String?       @map("gateway_tx_id")
  status      PaymentStatus @default(PENDING)
  paidAt         DateTime?     @map("paid_at")
  reminderSentAt DateTime?     @map("reminder_sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  order          Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Delivery {
  id          String         @id @default(uuid())
  orderId     String         @unique @map("order_id")
  driverId    String?        @map("driver_id")
  status      DeliveryStatus @default(PENDING)
  deliveredAt DateTime?      @map("delivered_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  driver      Staff?         @relation(fields: [driverId], references: [id])
  order       Order          @relation(fields: [orderId], references: [id])

  @@index([driverId])
  @@map("deliveries")
}

model Complaint {
  id          String          @id @default(uuid())
  orderId     String          @map("order_id")
  customerId  String          @map("customer_id")
  description String
  status      ComplaintStatus @default(OPEN)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt      @map("updated_at")
  customer    User            @relation(fields: [customerId], references: [id])
  order       Order           @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@map("complaints")
}

enum UserRole {
  CUSTOMER
}

enum StaffRole {
  SUPER_ADMIN
  OUTLET_ADMIN
  WORKER
  DRIVER
}

enum StationType {
  WASHING
  IRONING
  PACKING
}

enum PickupStatus {
  PENDING
  DRIVER_ASSIGNED
  PICKED_UP
  CANCELLED
}

enum OrderStatus {
  WAITING_FOR_PICKUP_DRIVER
  LAUNDRY_EN_ROUTE_TO_OUTLET
  LAUNDRY_ARRIVED_AT_OUTLET
  LAUNDRY_BEING_WASHED
  LAUNDRY_BEING_IRONED
  LAUNDRY_BEING_PACKED
  WAITING_FOR_PAYMENT
  LAUNDRY_READY_FOR_DELIVERY
  LAUNDRY_OUT_FOR_DELIVERY
  LAUNDRY_DELIVERED_TO_CUSTOMER
  COMPLETED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
}

enum StationStatus {
  IN_PROGRESS
  BYPASS_REQUESTED
  COMPLETED
}

enum BypassStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  DRIVER_ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

